\ProvidesPackage{beamerthemeIITiSPoster}

\usepackage{tikz}
\usepackage{xcolor}
\usepackage{braket}
\usepackage{subfig}
\usepackage{wrapfig} % in preamble
\usepackage{svg}

% Colors
\definecolor{iitis-gray}{RGB}{131,130,128}
\definecolor{iitis-orange}{RGB}{230,120,23}

% Beamer Color Settings
\setbeamercolor{headline}{bg=white,fg=iitis-orange}
\setbeamercolor{footline}{bg=iitis-gray,fg=white}
\setbeamercolor{title in headline}{fg=iitis-orange}
\setbeamercolor{author in headline}{fg=iitis-gray}
\setbeamercolor{block title}{fg=white,bg=iitis-orange}
\setbeamercolor{block body}{fg=black,bg=white}
\setbeamercolor{item}{fg=iitis-orange}

% Fonts
\usefonttheme{professionalfonts}
\setbeamerfont{title}{size=\Huge, series=\bfseries}
\setbeamerfont{author}{size=\Large}
\setbeamerfont{block title}{size=\Large, series=\bfseries}

% TikZ Logo Definition
\def\e{0.2}
\newcommand{\iitislogo}[1]{%
	\begin{tikzpicture}[scale=#1]%
		\fill[color=iitis-gray] (2,0) rectangle (3,1);%
		\fill[color=iitis-gray] (2,4) rectangle (3,5);%
		\fill[color=iitis-gray] ({0-2*\e},2) rectangle ({1-2*\e},3);%
		\fill[color=iitis-orange] ({1-\e},2) rectangle ({2-\e},3);%
		\fill[color=iitis-orange] (2,2) rectangle (3,3);%
		\fill[color=iitis-orange] (4,2) rectangle (5,3);%
		\fill[color=iitis-orange] (3,3) rectangle (4,4);%
		\fill[color=iitis-orange] (3,1) rectangle (4,2);%
	\end{tikzpicture}%
}

% Header Template
\setbeamertemplate{headline}{
	\leavevmode
	\begin{beamercolorbox}[wd=\paperwidth]{headline}
		\begin{columns}[T]
			\begin{column}{.15\paperwidth}
				\centering
				\vspace{2cm}
				\iitislogo{1.5}
			\end{column}
			\begin{column}{.7\paperwidth}
				\vskip4ex
				\raggedright
				\usebeamercolor{title in headline}{\color{fg}\textbf{\Huge{\inserttitle}}\\[1ex]}
				\usebeamercolor{author in headline}{\color{fg}\Large{\insertauthor}\\[1ex]}
				\usebeamercolor{institute in headline}{\color{fg}\large{\insertinstitute}\\[1ex]}
			\end{column}
			\begin{column}{.15\paperwidth}
			\end{column}
		\end{columns}
		\vspace{2ex}
		\hrules % Custom line below header
	\end{beamercolorbox}
}

% Block Template
\setbeamertemplate{block begin}{
	\vspace{1ex}
	\begin{beamercolorbox}[sep=1ex,left,rounded=true,shadow=false]{block title}
		\usebeamerfont*{block title}\insertblocktitle
	\end{beamercolorbox}
	\setbeamercolor{at}{fg=black,bg=white}
	\begin{beamercolorbox}[sep=1ex,left,rounded=true]{block body}
		}
		\setbeamertemplate{block end}{\end{beamercolorbox}}

